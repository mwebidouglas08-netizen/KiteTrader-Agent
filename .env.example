# KiteTrader Environment Variables
# Copy this to .env and fill in your values

# Kite Chain Configuration
KITE_RPC_URL=https://rpc-testnet.kiteai.io
AGENT_PRIVATE_KEY=your_agent_wallet_private_key_here
ATTESTATION_CONTRACT=0x_your_deployed_contract_address

# Server
PORT=3001

# Optional: Real market data (leave blank for simulation)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Optional: Notifications
SLACK_WEBHOOK_URL=
